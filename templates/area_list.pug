-extends 'index.pug'
-load static i18n

block content
  .app.bio-index
    // navigation pane
    .navigation.bio-navigation
      a.brand-link(href="/", aria-label="Wohnbiografien")
        h1.wordmark
          span WOHN
          span BIO
          span GRAF
          span IEN
      .brand-rule

      .controls
        .control-group
          label(for="city-filter") Stadt:
          select#city-filter(v-model="country", @change="updateGraphs")
            option(value="") Alle
            - for city in cities
              option {{ city }}
        -verbatim
          .control-group.age-control
            .control-label Alter: {{ minAge }} - {{ maxAge }} Jahre
            #age-slider.fly.wrap
      .navigation-spacer
      .studio-mark
        .studio-logo LUD°
        .studio-text Laboratory for Architecture
          br
          | and Urban Density

    .list-area
      -for graph in object_list
        -include 'partials/naked_graph_with_name.pug'

    #graphView.modal.fade(role="dialog", tabindex="-1")
      .modal-dialog
        .modal-content
          .modal-body
            .title(v-text="currentGraph")
            .subtitle wohnt auf durchschnittlich
              span(v-text="' ' + currentMedian")
              | m² im Jahr
            button.close(type="button", data-dismiss="modal", aria-label="Close")
              span(aria-hidden="true") &times;
            .graph-area
            #legend
              div(v-show='false')
                | Kurze Lebensabschnitte (Alter)
                .entries
            #main-legend Legende
              .entries
                span.marker.bg-gray &nbsp;
                |  gesamte Wohnfläche
                br
                span.marker.bg-red &nbsp;
                |  Wohnfläche pro Person
                br
                span.marker.bg-yellow &nbsp;
                |  künftige Wohnfläche

block extra_script
  script(src="{% static 'js/omni-slider.js' %}")
  script(src="{% static 'js/vue.js' %}")
  script(src="{% static 'js/superagent.js' %}")
  script(src="{% static 'js/area_list.js' %}")
